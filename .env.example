# Google OAuth Credentials
# Create at: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
# Enable: Gmail API + Google Sheets API + Google People API
# Authorized redirect URI: https://venue-booker.netlify.app/.netlify/functions/auth-callback

GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Optional: iOS native sign-in (defaults match capacitor.config.json if unset)
# VITE_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com

# Netlify sets this automatically. Override for local dev:
URL=https://venue-booker.netlify.app

# Capacitor iOS/Android: full URL of your Netlify site so email + survey functions are reachable
# (defaults in code to https://venue-booker.netlify.app if unset). Set when you use a custom domain.
# VITE_NETLIFY_SITE_URL=https://venue-booker.netlify.app

# Optional: override Supabase Edge Function URL for venue-data (default: project functions URL).
# VITE_SUPABASE_FUNCTIONS_URL=https://YOUR_PROJECT.supabase.co/functions/v1/venue-data
